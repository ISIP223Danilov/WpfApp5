<Window x:Class="WpfApp5.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="400" Width="350">

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="30">

            <!-- Заголовок -->
            <TextBlock Text="ВХОД В СИСТЕМУ" FontSize="24" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Поле для логина -->
            <TextBlock Text="Логин:"/>
            <TextBox x:Name="txtLogin" Height="35" Margin="0,0,0,10"/>

            <!-- Поле для пароля -->
            <TextBlock Text="Пароль:"/>
            <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,20"/>

            <!-- Место для ошибки -->
            <TextBlock x:Name="txtError" Foreground="Red" Visibility="Collapsed"/>

            <!-- Кнопка входа -->
            <Button Content="ВОЙТИ" Height="40" Background="Green" 
                    Foreground="White" Click="Login_Click"/>

        </StackPanel>
    </Grid>
</Window>
