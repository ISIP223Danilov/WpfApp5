<Page x:Class="WpfApp5.glavOknO"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp5"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="glavOknO">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="9*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>
        <ListBox Name = "Hairsss" ScrollViewer.HorizontalScrollBarVisibility="Disabled" d:ItemsSource="{d:SampleData ItemCount=5}" Grid.ColumnSpan="2" Grid.Row="1">
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Height="100" Width="160"  Source="{Binding Image}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Padding="5" Text="{Binding Name}" TextWrapping="Wrap"/>
                            <TextBlock Padding="5" Text="{Binding Price, StringFormat=Цена: {0}}"/>

                        </StackPanel>
                        <Button Click="Button_Click" Height="40" Content="Выбрать" ></Button>
                    </StackPanel>
                </DataTemplate>  
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel>
                        
                    </WrapPanel>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        <ComboBox x:Name="SortComboBox" Margin="5" SelectedIndex="0" SelectionChanged="SortComboBox_SelectionChanged">
            <ComboBoxItem Content="Цена убывание"/>
            <ComboBoxItem Content="Цена увеличение"/>
        </ComboBox>
    </Grid>
</Page>
