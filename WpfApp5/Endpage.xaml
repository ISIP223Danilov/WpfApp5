<Page x:Class="WpfApp5.Endpage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp5"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Endpage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" Height="300" Width="150">
            <TextBlock Padding="5" Text="{Binding FullName}" TextWrapping="Wrap"/>
            <TextBlock Padding="5" Text="{Binding Rating, StringFormat=Мастер: {0}}"/>
            <TextBlock Padding="5" Text="{Binding Rating, StringFormat=Цена: {0}}"/>
            <DatePicker x:Name="DeliveryDatePicker"  Margin="5" DisplayDateStart="{Binding MinDate, Mode=OneWay}" />
            <Button Height="40" Content="Каллендарь" ></Button>
            
        </StackPanel>
    </Grid>
</Page>
